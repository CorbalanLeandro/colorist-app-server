{
  "name": "colorist-app-server",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "node dist/src/main",
    "dev": "nest start --watch",
    "dev:debug": "nest start --debug --watch",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest --config ./jest.config.js --verbose --runInBand",
    "test:watch": "jest --config ./jest.config.js --watch",
    "test:cov": "jest --config ./jest.config.js --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --config ./jest.config.js --runInBand",
    "test:e2e": "jest --config ./test-e2e/jest-e2e.json"
  },
  "dependencies": {
    "@nestjs/common": "11.1.18",
    "@nestjs/config": "4.0.3",
    "@nestjs/core": "11.1.18",
    "@nestjs/jwt": "11.0.2",
    "@nestjs/mongoose": "11.0.4",
    "@nestjs/platform-express": "11.1.18",
    "@nestjs/swagger": "11.2.6",
    "@nestjs/terminus": "11.1.1",
    "@nestjs/throttler": "6.5.0",
    "class-transformer": "0.5.1",
    "class-validator": "0.15.1",
    "date-fns": "4.1.0",
    "helmet": "8.1.0",
    "mongodb": "7.1.0",
    "mongoose": "9.4.1",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2"
  },
  "devDependencies": {
    "@nestjs/cli": "11.0.17",
    "@nestjs/schematics": "11.0.10",
    "@nestjs/testing": "11.1.18",
    "@types/express": "5.0.6",
    "@types/jest": "29.5.14",
    "@types/node": "22.19.17",
    "@types/supertest": "7.2.0",
    "@typescript-eslint/eslint-plugin": "8.58.0",
    "@typescript-eslint/parser": "8.58.0",
    "eslint": "8.57.1",
    "eslint-config-prettier": "9.1.2",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-typescript-sort-keys": "3.3.0",
    "jest": "29.7.0",
    "prettier": "3.8.1",
    "source-map-support": "0.5.21",
    "supertest": "7.2.2",
    "ts-jest": "29.4.9",
    "ts-loader": "9.5.7",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.9.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
